{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "IELTS Speaking Copilot",
  "version": "0.1.0",
  "identifier": "com.ieltsspeaking.copilot",
  "build": {
    "beforeDevCommand": "npm.cmd run dev:tauri",
    "devUrl": "http://127.0.0.1:3000",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../out"
  },
  "app": {
    "windows": [
      {
        "title": "IELTS Speaking Copilot",
        "width": 1440,
        "height": 920,
        "minWidth": 1100,
        "minHeight": 720
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.ico"]
  }
}
